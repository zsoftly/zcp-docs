# Keep the build context small and stop host artifacts from leaking into the
# image. The builder reinstalls dependencies itself; copying a host (e.g. macOS)
# node_modules over the freshly installed one via `COPY . .` would clobber the
# Linux Sharp native binary and break image optimization.
node_modules
dist
.astro
tmp
*.log

# Exclude the git object store but keep the tiny ref files the footer commit
# stamp reads (build-info.mjs), so the build context stays lean.
.git
!.git/HEAD
!.git/packed-refs
!.git/refs
!.git/refs/**
