---
// PageFrame override: injects the site-wide promotional announcement bar
// above Starlight's fixed nav header.
import Default from '@astrojs/starlight/components/PageFrame.astro';
import type { Props } from '@astrojs/starlight/props';
---

{/* Prevent FOUC: runs synchronously before paint */}
<script is:inline>
  if (sessionStorage.getItem('zs-promo-dismissed') === '1') {
    document.documentElement.setAttribute('data-promo-dismissed', '');
  }
</script>

<div id="promo-bar" class="promo-bar" role="region" aria-label="Promotional offer">
  <div class="promo-inner">
    <span class="promo-live" aria-label="Live offer">
      <span class="live-dot" aria-hidden="true"></span>
      Live
    </span>
    <span class="promo-sep" aria-hidden="true">·</span>
    <span class="promo-text">$300 credit for new accounts</span>
    <span class="promo-sep" aria-hidden="true">·</span>
    <span class="promo-text">Valid for 60 days from account creation</span>
    <span class="promo-sep" aria-hidden="true">·</span>
    <a
      href="https://cloud.zcp.zsoftly.ca/register"
      class="promo-cta"
      target="_blank"
      rel="noopener noreferrer"
    >
      Get started →
    </a>
  </div>
  <button id="promo-dismiss" class="promo-dismiss" type="button" aria-label="Dismiss announcement">
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="14"
      height="14"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      aria-hidden="true"
    >
      <line x1="18" y1="6" x2="6" y2="18"></line>
      <line x1="6" y1="6" x2="18" y2="18"></line>
    </svg>
  </button>
</div>

<Default {...Astro.props}>
  <slot name="header" slot="header" />
  <slot name="sidebar" slot="sidebar" />
  <slot />
</Default>

<script>
  document.getElementById('promo-dismiss')?.addEventListener('click', () => {
    sessionStorage.setItem('zs-promo-dismissed', '1');
    document.documentElement.setAttribute('data-promo-dismissed', '');
  });
</script>

<style>
  .promo-bar {
    position: fixed;
    inset-inline: 0;
    inset-block-start: 0;
    z-index: 9999;
    height: var(--sl-announcement-height, 2.5rem);
    background-color: #00198a;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-inline: 1rem;
    gap: 0.75rem;
  }

  :root[data-promo-dismissed] .promo-bar {
    display: none;
  }

  .promo-inner {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.9);
    flex-wrap: nowrap;
    overflow: hidden;
  }

  .promo-live {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-weight: 600;
    color: #ffffff;
    white-space: nowrap;
  }

  .live-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: #4ade80;
    flex-shrink: 0;
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%,
    100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.6;
      transform: scale(0.85);
    }
  }

  .promo-sep {
    color: rgba(255, 255, 255, 0.35);
    flex-shrink: 0;
  }

  .promo-text {
    white-space: nowrap;
    color: rgba(255, 255, 255, 0.85);
  }

  /* Hide less important items on narrow screens */
  @media (max-width: 640px) {
    .promo-text:nth-of-type(2),
    .promo-text:nth-of-type(3),
    .promo-sep:nth-of-type(2),
    .promo-sep:nth-of-type(3),
    .promo-sep:nth-of-type(4) {
      display: none;
    }
  }

  .promo-cta {
    color: #ffffff !important;
    font-weight: 600;
    text-decoration: none !important;
    white-space: nowrap;
    border-bottom: 1px solid rgba(255, 255, 255, 0.4);
    padding-bottom: 1px;
    transition: border-color 150ms ease;
    flex-shrink: 0;
  }

  .promo-cta:hover {
    border-bottom-color: rgba(255, 255, 255, 0.9);
    text-decoration: none !important;
  }

  .promo-dismiss {
    position: absolute;
    inset-inline-end: 0.75rem;
    background: transparent;
    border: none;
    cursor: pointer;
    color: rgba(255, 255, 255, 0.6);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.25rem;
    border-radius: 4px;
    transition:
      color 150ms ease,
      background-color 150ms ease;
    flex-shrink: 0;
  }

  .promo-dismiss:hover {
    color: #ffffff;
    background-color: rgba(255, 255, 255, 0.1);
  }
</style>
