      {Astro.locals.t('zs.promo.live')}
    </span>
    <span class="promo-sep" aria-hidden="true">·</span>
    <span class="promo-text">{Astro.locals.t('zs.promo.credit')}</span>
    <span class="promo-sep" aria-hidden="true">·</span>
    <span class="promo-text">{Astro.locals.t('zs.promo.ends')}</span>
    <span class="promo-sep" aria-hidden="true">·</span>
    <a
      href="https://cloud.zcp.zsoftly.ca/register"
      class="promo-cta"
      target="_blank"
      rel="noopener noreferrer"
    >
      {Astro.locals.t('zs.promo.cta')}
    </a>
  </div>
  <button
    id="promo-dismiss"
    class="promo-dismiss"
    type="button"
    aria-label={Astro.locals.t('zs.promo.dismiss')}
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="14"
      height="14"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      aria-hidden="true"
    >
      <line x1="18" y1="6" x2="6" y2="18"></line>
      <line x1="6" y1="6" x2="18" y2="18"></line>
    </svg>
  </button>
</div>

<Default {...Astro.props}>
  <slot name="header" slot="header" />
  <slot name="sidebar" slot="sidebar" />
  <slot />
</Default>

<div
  id="sidebar-resizer"
  class="sidebar-resizer"
  role="separator"
  aria-orientation="vertical"
  aria-label={Astro.locals.t('zs.resize.sidebar')}
  tabindex="0"
>
</div>

<div
  id="toc-resizer"
  class="toc-resizer"
  role="separator"
  aria-orientation="vertical"
  aria-label={Astro.locals.t('zs.resize.toc')}
  tabindex="0"
>
</div>

<script>
  document.getElementById('promo-dismiss')?.addEventListener('click', () => {
    sessionStorage.setItem('zs-promo-dismissed', '1');
    document.documentElement.setAttribute('data-promo-dismissed', '');
  });

  // ── Resizable layout (left sidebar + right TOC) ─────────────
  // Each handle drives a CSS custom property; the content column (main-pane)
  // is flex: 1 in custom.css, so it absorbs whatever space the sidebar or TOC
  // gives up. The handles reposition themselves via CSS (left/right bound to
  // the same variables), so we only need to update the variable.
  const root = document.documentElement;
  const remPerPx = () => 1 / parseFloat(getComputedStyle(root).fontSize);
  const STEP_PX = 10; // keyboard arrow step

  interface Handle {
    el: HTMLElement | null;
    cssVar: string;
    storageKey: string;
    min: number;
    max: number;
    invertKeys: boolean;
    fromEvent: (e: MouseEvent) => number;
  }

  function initHandle(h: Handle) {
    if (!h.el) return;
    let px = 0;

    const apply = (value: number) => {
      px = Math.min(Math.max(value, h.min), h.max);
      root.style.setProperty(h.cssVar, `${(px * remPerPx()).toFixed(3)}rem`);
    };
    // localStorage can throw in private mode / when storage is disabled —
    // guard it so the resize feature never breaks the page.
    const persist = () => {
      try {
        localStorage.setItem(h.storageKey, String(px));
      } catch {
        /* storage unavailable — ignore */
      }
    };

    let saved = NaN;
    try {
      saved = Number(localStorage.getItem(h.storageKey));
    } catch {
      /* storage unavailable — ignore */
    }
    if (Number.isFinite(saved) && saved > 0) apply(saved);

    let dragging = false;
    h.el.addEventListener('mousedown', (e: MouseEvent) => {
      dragging = true;
      document.body.style.cursor = 'col-resize';
      document.body.style.userSelect = 'none';
      e.preventDefault();
    });
    document.addEventListener('mousemove', (e: MouseEvent) => {
      if (dragging) apply(h.fromEvent(e));
    });
    document.addEventListener('mouseup', () => {
      if (!dragging) return;
      dragging = false;
      document.body.style.cursor = '';
      document.body.style.userSelect = '';
      persist();
    });
    h.el.addEventListener('keydown', (e: KeyboardEvent) => {
      const dir = e.key === 'ArrowLeft' ? -1 : e.key === 'ArrowRight' ? 1 : 0;
      if (!dir) return;
      apply(px + dir * STEP_PX * (h.invertKeys ? -1 : 1));
      persist();
      e.preventDefault();
    });
  }

  // Left sidebar: handle on the sidebar's right edge; dragging right widens it.
  initHandle({
    el: document.getElementById('sidebar-resizer'),
    cssVar: '--sl-sidebar-width',
    storageKey: 'zs-sidebar-width',
    min: 180,
    max: 480,
    invertKeys: false,
    fromEvent: (e) => e.clientX,
  });

  // Right TOC: handle on the TOC's left edge; dragging left widens it.
  initHandle({
    el: document.getElementById('toc-resizer'),
    cssVar: '--toc-width',
    storageKey: 'zs-toc-width',
    min: 192,
    max: 448,
    invertKeys: true,
    fromEvent: (e) => window.innerWidth - e.clientX,
  });
</script>

<style>
  .promo-bar {
    position: fixed;
    inset-inline: 0;
    inset-block-start: 0;
    z-index: 9999;
    height: var(--sl-announcement-height, 2.5rem);
    background-color: #00198a;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-inline: 1rem;
    gap: 0.75rem;
  }

  :root[data-promo-dismissed] .promo-bar {
    display: none;
  }

  .promo-inner {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.9);
    flex-wrap: nowrap;
    overflow: hidden;
  }

  .promo-live {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-weight: 600;
    color: #ffffff;
    white-space: nowrap;
  }

  .live-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: #4ade80;
    flex-shrink: 0;
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%,
    100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.6;
      transform: scale(0.85);
    }
  }

  .promo-sep {
    color: rgba(255, 255, 255, 0.35);
    flex-shrink: 0;
  }

  .promo-text {
    white-space: nowrap;
    color: rgba(255, 255, 255, 0.85);
  }

  /* Hide less important items on narrow screens */
  @media (max-width: 640px) {
    .promo-text:nth-of-type(2),
    .promo-text:nth-of-type(3),
    .promo-sep:nth-of-type(2),
    .promo-sep:nth-of-type(3),
    .promo-sep:nth-of-type(4) {
      display: none;
    }
  }

  .promo-cta {
    color: #ffffff !important;
    font-weight: 600;
    text-decoration: none !important;
    white-space: nowrap;
    border-bottom: 1px solid rgba(255, 255, 255, 0.4);
    padding-bottom: 1px;
    transition: border-color 150ms ease;
    flex-shrink: 0;
  }

  .promo-cta:hover {
    border-bottom-color: rgba(255, 255, 255, 0.9);
    text-decoration: none !important;
  }

  .promo-dismiss {
    position: absolute;
    inset-inline-end: 0.75rem;
    background: transparent;
    border: none;
    cursor: pointer;
    color: rgba(255, 255, 255, 0.6);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.25rem;
    border-radius: 4px;
    transition:
      color 150ms ease,
      background-color 150ms ease;
    flex-shrink: 0;
  }

  .promo-dismiss:hover {
    color: #ffffff;
    background-color: rgba(255, 255, 255, 0.1);
  }

  .promo-dismiss:focus-visible {
    outline: 2px solid rgba(255, 255, 255, 0.8);
    outline-offset: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .live-dot {
      animation: none;
    }
  }
</style>
