{
  "name": "zcp-docs",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "typecheck": "astro sync && tsc --noEmit",
    "fmt": "prettier --write \"**/*.{ts,tsx,astro,md,mdx,json,yml,yaml}\"",
    "fmt:check": "prettier --check \"**/*.{ts,tsx,astro,md,mdx,json,yml,yaml}\"",
    "lint": "eslint src"
  },
  "dependencies": {
    "@astrojs/starlight": "^0.39.2",
    "astro": "^6.4.2",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "eslint-plugin-astro": "^1.0.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "starlight-links-validator": "^0.24.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.60.0"
  },
  "pnpm": {
    "overrides": {
      "nanoid": "3.3.4",
      "esbuild@>=0.17.0 <0.28.1": "0.28.1",
      "vite@>=7.0.0 <7.3.5": "7.3.5"
    }
  },
  "engines": {
    "node": ">=20.0"
  }
}
